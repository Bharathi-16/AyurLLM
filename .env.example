# AyurParam AI — Configuration
# Copy this to .env and modify as needed

# Model
MODEL_ID=bharatgenai/AyurParam
# DEVICE_OVERRIDE=cpu  # Force device: cpu, cuda, mps

# Server
HOST=0.0.0.0
PORT=8080
SECRET_KEY=change-this-to-a-random-string-in-production

# Limits
MAX_UPLOAD_MB=10
MAX_MESSAGE_LENGTH=4096

# Debug
DEBUG=false
LOG_LEVEL=INFO
